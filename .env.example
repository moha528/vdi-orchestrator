# ═══════════════════════════════════════════════════════
#  VDI Orchestrator — Environment Variables
#  Copy this file to .env and adjust values accordingly
# ═══════════════════════════════════════════════════════

# ── Proxmox VE ──
PROXMOX_HOST=192.168.80.10
PROXMOX_PORT=8006
PROXMOX_USER=root@pam
PROXMOX_PASSWORD=<your-proxmox-password>
PROXMOX_NODE=proxmox

# ── Guacamole Database ──
GUAC_DB_HOST=guac-db
GUAC_DB_PORT=5432
GUAC_DB_NAME=guacamole_db
GUAC_DB_USER=guacamole_user
GUAC_DB_PASSWORD=<your-guacamole-db-password>
GUAC_URL=http://guacamole:8080/guacamole

# ── Clone Pool ──
CLONE_POOL_START_ID=500
CLONE_POOL_END_ID=550
CLONE_NAME_PREFIX=vdi-
POLL_INTERVAL=3
POLL_TIMEOUT=120

# ── Monitoring / Lifecycle ──
MONITOR_INTERVAL=15
UNUSED_TIMEOUT=300
MAX_CLONE_LIFETIME=14400
ORPHAN_SCAN_INTERVAL=120

# ── Security ──
# Leave empty to auto-generate (not recommended in production)
SECRET_KEY=
EXTRA_ADMINS=

# ── Guacamole Auth-JSON (SSO) ──
# 128-bit hex key shared with guacamole-auth-json extension
# Generate with: python -c "import secrets; print(secrets.token_hex(16))"
# Must match json-secret-key in guac-config/guacamole.properties
GUAC_JSON_SECRET=

# ── Backup ──
BACKUP_ENABLED=true
BACKUP_DIR=/srv/backups
BACKUP_MAX_SIZE_MB=200
BACKUP_VM_USER=etudiant
