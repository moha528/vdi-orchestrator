# ╔══════════════════════════════════════════════════════════════╗
# ║              VDI Orchestrator — Configuration               ║
# ╚══════════════════════════════════════════════════════════════╝
# Copier ce fichier en .env et adapter les valeurs.

# ── Proxmox VE ──────────────────────────────────────────────
PROXMOX_HOST=192.168.1.100          # IP ou hostname du noeud Proxmox
PROXMOX_PORT=8006
PROXMOX_USER=root@pam
PROXMOX_PASSWORD=changeme           # OBLIGATOIRE
PROXMOX_NODE=proxmox                # nom du noeud dans Proxmox

# ── Base de donnees (partagee entre Guacamole et l'orchestrateur) ──
GUAC_DB_PASSWORD=changeme           # mot de passe PostgreSQL

# ── Guacamole auth-json (SSO) ──────────────────────────────
# Cle HEX 128-bit (32 caracteres hex). Generer avec :
#   python3 -c "import secrets; print(secrets.token_hex(16))"
GUAC_JSON_SECRET=changeme

# ── URL publique de Guacamole (vue du navigateur de l'utilisateur) ──
GUAC_URL=http://192.168.1.100:8080/guacamole

# ── Session / Securite ──────────────────────────────────────
SECRET_KEY=changeme                 # cookie signing, generer avec : python3 -c "import secrets; print(secrets.token_hex(32))"
EXTRA_ADMINS=                       # CSV d'usernames supplementaires consideres admin

# ── Clone Pool ──────────────────────────────────────────────
CLONE_POOL_START_ID=500             # VMID de debut pour les clones
CLONE_POOL_END_ID=550               # VMID de fin (exclus)
CLONE_NAME_PREFIX=vdi-

# ── Timeouts ────────────────────────────────────────────────
POLL_INTERVAL=3                     # secondes entre chaque poll pendant le provisioning
POLL_TIMEOUT=120                    # timeout max du provisioning (secondes)
MONITOR_INTERVAL=15                 # interval du session monitor (secondes)
UNUSED_TIMEOUT=300                  # destruction si jamais connecte apres N secondes
MAX_CLONE_LIFETIME=14400            # duree de vie max d'un clone (4h)
ORPHAN_SCAN_INTERVAL=120            # interval du scan des VMs orphelines

# ── Backups ─────────────────────────────────────────────────
BACKUP_ENABLED=true
BACKUP_MAX_SIZE_MB=500
BACKUP_VM_USER=etudiant             # user SSH sur les VMs pour les backups
